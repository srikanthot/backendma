# -----------------------------
# Azure OpenAI
# -----------------------------
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=your-embeddings-deployment

# -----------------------------
# Azure AI Search
# -----------------------------
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_INDEX=your-index-name

# -----------------------------
# Index field mappings
# These must match your Azure AI Search index schema exactly
# -----------------------------
SEARCH_CONTENT_FIELD=chunk
SEARCH_VECTOR_FIELD=text_vector
SEARCH_TITLE_FIELD=title
SEARCH_FILENAME_FIELD=source_file
SEARCH_URL_FIELD=source_url
SEARCH_CHUNK_ID_FIELD=chunk_id
SEARCH_PAGE_FIELD=
SEARCH_SECTION1_FIELD=header_1
SEARCH_SECTION2_FIELD=header_2
SEARCH_SECTION3_FIELD=header_3

# -----------------------------
# Retrieval tuning
# -----------------------------
TOP_K=5
VECTOR_K=50
MAX_CONTEXT_CHUNKS=5
MIN_RELEVANCE_SCORE=0.01
MIN_RERANKER_SCORE=0.5
USE_SEMANTIC_RERANKER=true
SEMANTIC_CONFIG_NAME=manual-semantic-config

# -----------------------------
# CORS
# Comma-separated list
# -----------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------
# Logging / diagnostics
# -----------------------------
TRACE_MODE=true
LOG_LEVEL=INFO
LOG_LEVEL=INFO
